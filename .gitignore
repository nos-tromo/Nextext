# ==================================
# Exceptions
# ==================================
# React frontend (frontend/) — unblock file types the pattern rules would swallow
!frontend/index.html
!frontend/src/lib/
!frontend/nginx/*.conf
!**/.github/
!**/.github/workflows/
!**/.github/workflows/ci.yml
!**/.github/workflows/codeql.yml
!**/prompts/
!**/prompts/**/*.txt
!**/scripts/
!**/scripts/bundle_images.sh
!**/scripts/bundle-lib.sh
!**/scripts/create_docker_volumes.sh
!.dockerignore
!.env.example
!.gitignore
!.pre-commit-config.yaml
!AGENTS.md
!CLAUDE.md
# Design specs from the brainstorming flow are tracked despite the *.md ignore.
!docs/superpowers/specs/*.md
# Per-host job persistence (created by NEXTEXT_DATA_DIR default)
.nextext-data/
