ARG UV_IMAGE=ghcr.io/astral-sh/uv:0.11.9-python3.12-trixie-slim@sha256:26c7a2f9dcbaf11fb7822963640ab60a4e0f6b23e9ba5a31a88686146003f83e

FROM $UV_IMAGE

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONIOENCODING=utf-8 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    UV_CACHE_DIR=/root/.cache/uv \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:$PATH"

WORKDIR /app

# Install only the lightweight frontend dependency group. Heavy ML deps
# (torch, openai-whisper, pyannote, GLiNER, spaCy) stay out of this image
# because the FastAPI backend owns them.
RUN --mount=type=cache,target=${UV_CACHE_DIR} \
    --mount=type=bind,source=uv.lock,target=uv.lock \
    --mount=type=bind,source=pyproject.toml,target=pyproject.toml \
    uv sync --locked --only-group frontend

COPY nextext/__init__.py nextext/__init__.py
COPY nextext/frontend/ nextext/frontend/
COPY nextext/utils/mappings/ nextext/utils/mappings/

EXPOSE 8501

CMD ["streamlit", "run", "nextext/frontend/app.py", \
     "--server.address", "0.0.0.0", "--server.port", "8501", \
     "--server.fileWatcherType", "none"]
