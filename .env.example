# INFERENCE_NETWORK=inference-net
# NEXTEXT_OFFLINE=1                     # Gate spaCy/NLTK downloads (1 = offline, default).
# NEXTEXT_HOST_PORT=8501                # Host port exposed by the frontend container.
# PRELOAD_MODELS=true                   # Run load-models (spaCy + NLTK) at container start.

# =============================================================================
# Frontend → backend wiring (Docker)
# =============================================================================
# The Streamlit frontend reaches the FastAPI backend over HTTP. Inside the
# compose network both services are aliased so the defaults below match the
# shipped docker-compose.yml without further configuration.
# BACKEND_HOST=http://backend:8000          # Frontend uses this URL (inside the network).
# BACKEND_PUBLIC_HOST=http://localhost:8000 # Surfaced in UI hints for external clients.

# =============================================================================
# Backend tuning
# =============================================================================
# NEXTEXT_API_HOST=0.0.0.0                  # Bind address for uvicorn.
# NEXTEXT_API_PORT=8000                     # Bind port (inside the container).
# NEXTEXT_MAX_UPLOAD_MB=8192                # Hard cap on per-upload size.

# =============================================================================
# Identity (session-scoped, stateless)
# =============================================================================
# The backend has no authentication. Each request carries a trusted identity
# header used only to scope the caller's in-memory jobs so two browsers stay
# isolated. The Streamlit frontend mints a per-browser id and carries it in
# the page URL (?owner=<id>); developers and any header-less client fall back
# to NEXTEXT_DEFAULT_IDENTITY. With neither header nor default set, the API
# returns 401. Jobs live only in memory — there is no durable storage and no
# TTL; a run survives a browser reload but not a backend restart.
# NEXTEXT_AUTH_HEADER=X-Auth-User           # Trusted identity header name.
# NEXTEXT_DEFAULT_IDENTITY=                 # Dev / header-less fallback identity.

# =============================================================================
# Inference endpoints
# =============================================================================
# ALL model inference runs on external services. The central endpoint is the
# OPENAI_API_BASE/OPENAI_API_KEY pair (chat: translation, summarization,
# hate-speech detection — one chat model serves every text task via
# TEXT_MODEL). Whisper can be re-pointed at a dedicated endpoint and otherwise
# falls back to the central pair; NER, diarization, and VAD are dedicated-only:
#
#   Whisper      WHISPER_API_BASE / WHISPER_API_KEY     (OpenAI SDK base, incl. /v1)
#   GLiNER NER   NER_API_BASE                           (service root, POST {base}/gliner)
#   Diarization  DIARIZE_API_BASE                       (service root, POST {base}/diarize)
#   VAD          VAD_API_BASE                           (service root, POST {base}/vad)
#
# Whisper falls back to the central OPENAI_API_BASE/OPENAI_API_KEY pair when its
# dedicated override is unset. WHISPER_MODEL defaults per provider: whisper-1
# (openai) or openai/whisper-large-v3 (vllm). Ollama serves no transcription
# API, so with INFERENCE_PROVIDER=ollama both WHISPER_API_BASE and WHISPER_MODEL
# must be set explicitly (e.g. the vllm-service audio container or any
# standalone OpenAI-compatible STT server).
#
# NER, diarization, and VAD have NO central fallback: leave NER_API_BASE /
# DIARIZE_API_BASE / VAD_API_BASE unset to DISABLE that stage (no entity table /
# no speaker column / no speech pre-filter — every file is then transcribed).
# Point each at the service ROOT — the client appends /gliner, /diarize, and
# /vad respectively (e.g. NER_API_BASE=http://vllm-router:4000 reaches
# .../gliner). Their bearer token is reused from OPENAI_API_KEY when set. The
# VAD guard is fail-open: an unreachable service transcribes anyway. vllm-service
# has no /diarize or /vad implementation yet, so those stages stay off until a
# service implements POST /diarize and POST /vad (see nextext/core/diarization.py
# and nextext/core/vad.py for the contracts).

# --- Per-model dedicated endpoints (optional) --------------------------------
# WHISPER_API_BASE=
# WHISPER_API_KEY=
# WHISPER_MODEL=
# NER_API_BASE=http://vllm-router:4000    # service root; client appends /gliner. Unset = NER disabled.
# NER_TIMEOUT=120                         # Seconds per NER request (per text chunk).
# DIARIZE_API_BASE=http://vllm-router:9000  # service root; client appends /diarize. Unset = diarization disabled.
# DIARIZE_TIMEOUT=600                     # Seconds per diarization request (can run minutes).
# VAD_API_BASE=http://vllm-router:7000    # service root; client appends /vad. Unset = speech guard disabled.
# VAD_TIMEOUT=60                          # Seconds per VAD request.

# =============================================================================
# Central inference provider — pick ONE block below and uncomment it.
# Defaults to "ollama" if INFERENCE_PROVIDER is unset.
#
# Translation, summarization, and hate-speech detection all use the templated
# prompts in nextext/utils/prompts/ and share TEXT_MODEL over OPENAI_API_BASE,
# so a single chat model on the endpoint serves every text task.
# =============================================================================

# --- Option 1: Ollama --------------------------------------------------------
# Ollama covers the text tasks only; transcription additionally needs the
# dedicated WHISPER_API_BASE + WHISPER_MODEL pair (see above).
# INFERENCE_PROVIDER=ollama
# OPENAI_API_BASE=http://ollama:11434/v1
# OPENAI_API_KEY=ollama
# TEXT_MODEL=gpt-oss:20b
# OLLAMA_THINK=0  # disable chain-of-thought on Qwen3 etc. (no-op for vLLM/openai)

# --- Option 2: vLLM via LiteLLM (nos-tromo/vllm-service) ---------------------
# One endpoint serves chat, Whisper (/v1/audio/transcriptions), and the
# /gliner pass-through — no dedicated overrides needed.
# INFERENCE_PROVIDER=vllm
# OPENAI_API_BASE=http://vllm-router:9000/v1
# OPENAI_API_KEY=<litellm master key>
# TEXT_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4

# --- Option 3: OpenAI (hosted) -----------------------------------------------
# Chat + Whisper served by OpenAI; NER/diarization still need dedicated
# endpoints (api.openai.com has no /gliner or /diarize).
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# TEXT_MODEL=gpt-4o

# Proxy bypass: NO_PROXY/no_proxy are set in docker-compose.yml with sensible
# defaults (service aliases + private CIDR ranges). To append extra hostnames,
# set EXTRA_NO_PROXY below (must start with a leading comma):
# EXTRA_NO_PROXY=,ollama,vllm-router
