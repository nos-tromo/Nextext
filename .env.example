# NEXTEXT_OFFLINE=1
# WHISPER_MODEL                         # External Whisper model name.
#                                       # Defaults: whisper-1 (openai) / openai/whisper-large-v3 (vllm).
#                                       # Ignored when INFERENCE_PROVIDER=ollama (local openai-whisper is used).
# HF_HUB_TOKEN=<your Hugging Face Hub token here>
# NEXTEXT_HOST_PORT=8501
# PRELOAD_MODELS=true
# NER_MODEL=gliner-community/gliner_large-v2.5

# =============================================================================
# Voice Activity Detection (VAD)
# =============================================================================
# Pre-screens audio with Silero VAD before running Whisper to skip files that
# contain noise but no human speech.  Uses torch.hub (no HF token required).
# Run `uv run load-models` once to cache the model for offline use.
# VAD_ENABLED=1                          # 1 (default) = enabled, 0 = disabled

# =============================================================================
# GPU model residency (controls VRAM usage across multi-file runs)
# =============================================================================
# Strategy the model registry applies when a caller releases a model:
#   offload (default) — move the model to CPU when idle, promote to GPU on next
#                       acquire. Keeps the weights cached in RAM; ~0.5-1 s
#                       transfer per file.
#   evict             — drop the instance entirely and reload from disk on next
#                       acquire. Maximum VRAM headroom between files; pays the
#                       full load time per file.
# MODEL_RESIDENCY_STRATEGY=offload
#
# Per-model overrides accept the same values and win over the global default.
# Supported names: gliner, whisper_turbo, whisper_large, diarization.
# MODEL_RESIDENCY_GLINER=evict
# MODEL_RESIDENCY_WHISPER_TURBO=offload
# MODEL_RESIDENCY_WHISPER_LARGE=offload
# MODEL_RESIDENCY_DIARIZATION=offload

# =============================================================================
# Inference provider — pick ONE block below and uncomment it.
# Defaults to "ollama" if INFERENCE_PROVIDER is unset.
#
# The translation pipeline branches on INFERENCE_PROVIDER:
#   - ollama / openai use the templated prompt in
#     nextext/utils/prompts/translation.txt plus a system prompt.
#   - vllm sends a single user message in the delimiter format required by
#     Infomaniak-AI/vllm-translategemma-4b-it (no system role).
#
# Summarization and hate-speech detection always use the templated prompt and
# share OPENAI_API_BASE with translation, so in vLLM mode the LiteLLM proxy
# must expose BOTH TEXT_MODEL and TRANSLATION_MODEL on the same endpoint.
# =============================================================================

# --- Option 1: Ollama (local, default) ---------------------------------------
# INFERENCE_PROVIDER=ollama
# OPENAI_API_BASE=http://ollama:11434/v1
# OPENAI_API_KEY=ollama
# TEXT_MODEL=gpt-oss:20b
# TRANSLATION_MODEL=translategemma:4b

# --- Option 2: vLLM via LiteLLM (nos-tromo/vllm-service) ---------------------
# INFERENCE_PROVIDER=vllm
# OPENAI_API_BASE=http://vllm-router:9000/v1
# OPENAI_API_KEY=<litellm master key>
# TEXT_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4
# TRANSLATION_MODEL=Infomaniak-AI/vllm-translategemma-4b-it

# --- Option 3: OpenAI (hosted) -----------------------------------------------
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# TEXT_MODEL=gpt-4o
# TRANSLATION_MODEL=gpt-4o

# --- Network proxy (optional) ---
# If your host must use an outbound proxy, put the values below in this file and
# start compose with `docker compose --env-file .env.docker ...` so the same
# proxy settings reach both image builds and running containers.
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,ollama,vllm-router
# Some tools prefer lowercase proxy variables. Duplicate the values below if needed.
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,ollama,vllm-router
# If the proxy or firewall blocks GitHub releases directly, set these to an
# internal mirror that serves the same spaCy wheel layout.
# SPACY_MODEL_DOWNLOAD_BASE_URL=https://github.example.com/spacy-models/releases/download
# SPACY_MODEL_PACKAGE_VERSION=3.8.0
# If Docker Hub is blocked directly in your environment, point these at an
# internal mirror or approved registry namespace that proxies the same images.
