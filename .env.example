# INFERENCE_NETWORK=inference-net
# NEXTEXT_OFFLINE=1                     # Gate spaCy/NLTK downloads (1 = offline, default).
# NEXTEXT_HOST_PORT=8501                # Host port exposed by the frontend (nginx) container.
# NEXTEXT_CLIENT_MAX_BODY_SIZE=8192m    # nginx client_max_body_size for the upload proxy.
# PRELOAD_MODELS=true                   # Run load-models (spaCy + NLTK) at container start.

# =============================================================================
# Backend tuning
# =============================================================================
# NEXTEXT_API_HOST=0.0.0.0                  # Bind address for uvicorn.
# NEXTEXT_API_PORT=8000                     # Bind port (inside the container).
# NEXTEXT_MAX_UPLOAD_MB=8192                # Hard cap on per-file upload size (backend; upload streamed to disk).
# NEXTEXT_DEFAULT_TARGET_LANG=en            # Initial translation target for a fresh browser (must be a supported code; defaults to English).
# NEXTEXT_JOB_CONCURRENCY=1                 # max jobs processed concurrently (1 = serial; raise to parallelize, bounded by CPU + inference capacity).

# =============================================================================
# Keyframe extraction defaults
# =============================================================================
# Server-side defaults for JobOptions.keyframes_per_minute / keyframes_max,
# consulted only when a job creation request omits the fields — an explicit
# per-request value always overrides them. KEYFRAMES_MAX is clamped to the
# JobOptions hard cap of 200; unparseable or otherwise out-of-range values
# fall back / clamp rather than failing (never raises, so a misconfigured
# value can't 500 every job). docint (the primary caller) always sends
# explicit values, so these mainly set the operator's default policy for
# other/omitting callers.
# KEYFRAMES_PER_MINUTE=4     # default keyframes sampled per minute of video (when a job omits it)
# KEYFRAMES_MAX=20           # default hard ceiling on frames per clip (clamped to <= 200)

# =============================================================================
# Identity (session-scoped, stateless)
# =============================================================================
# The backend has no authentication. Each request carries a trusted identity
# header used only to scope the caller's in-memory jobs so two browsers stay
# isolated. The React frontend mints a per-browser id and carries it in
# the page URL (?owner=<id>); developers and any header-less client fall back
# to NEXTEXT_DEFAULT_IDENTITY. With neither header nor default set, the API
# returns 401. Jobs live only in memory — there is no durable storage and no
# TTL; a run survives a browser reload but not a backend restart.
# NEXTEXT_AUTH_HEADER=X-Auth-User           # Trusted identity header name.
# NEXTEXT_DEFAULT_IDENTITY=                 # Dev / header-less fallback identity.

# =============================================================================
# Inference endpoints
# =============================================================================
# ALL model inference runs on external services. The central endpoint is the
# OPENAI_API_BASE/OPENAI_API_KEY pair — an OpenAI-SDK base (incl. /v1) that
# carries the text tasks (translation, summarization, hate-speech detection; one
# chat model via TEXT_MODEL) and is the fallback every other stage uses when its
# dedicated *_API_BASE override is unset:
#
#   Whisper      WHISPER_API_BASE / WHISPER_API_KEY     (OpenAI SDK base, incl. /v1)
#   GLiNER NER   NER_API_BASE                           (service root, POST {base}/gliner)
#   Diarization  DIARIZE_API_BASE                       (service root, POST {base}/diarize)
#   VAD          VAD_API_BASE                           (service root, POST {base}/vad)
#
# Whisper speaks the same OpenAI /v1 shape, so it reuses OPENAI_API_BASE verbatim.
# WHISPER_MODEL defaults per provider: whisper-1 (openai) or
# openai/whisper-large-v3 (vllm). Ollama serves no transcription API, so with
# INFERENCE_PROVIDER=ollama both WHISPER_API_BASE and WHISPER_MODEL must be set
# explicitly (an OpenAI-compatible STT server).
#
# NER, diarization, and VAD speak a plain service root, not the /v1 shape, so when
# they fall back to OPENAI_API_BASE one trailing /v1 is stripped before the client
# appends its path (OPENAI_API_BASE=http://vllm-router:4000/v1 reaches
# http://vllm-router:4000/gliner). Their bearer token is reused from
# OPENAI_API_KEY. NER and diarization run only when a job asks for entities / more
# than one speaker, so they need no off switch. The VAD guard runs on every
# transcription (fail-open: an unreachable service transcribes anyway); switch it
# off with VAD_API_BASE=off (also false / no / 0).

# --- Per-model dedicated endpoints (optional overrides) ----------------------
# Leave these unset to use the central OPENAI_API_BASE (NER/diarization/VAD strip
# one trailing /v1); set one only to point a single stage at a different endpoint.
# WHISPER_API_BASE=
# WHISPER_API_KEY=
# WHISPER_MODEL=
# NER_API_BASE=                # service root; client appends /gliner.
# NER_TIMEOUT=120              # Seconds per NER request (per text chunk).
# DIARIZE_API_BASE=            # service root; client appends /diarize.
# DIARIZE_TIMEOUT=600          # Seconds per diarization request (can run minutes).
# VAD_API_BASE=                # service root; client appends /vad. =off switches the guard off.
# VAD_TIMEOUT=60               # Seconds per VAD request.

# =============================================================================
# Central inference provider — pick ONE block below and uncomment it.
# Defaults to "ollama" if INFERENCE_PROVIDER is unset.
#
# Translation, summarization, and hate-speech detection all use the templated
# prompts in nextext/utils/prompts/ (localized per language under en/, de/) and
# share TEXT_MODEL over OPENAI_API_BASE, so a single chat model on the endpoint
# serves every text task.
#
# Response language — summaries and hate-speech rationales are generated from the
# localized prompts in nextext/utils/prompts/<code>/ (en, de). Set
# NEXTEXT_RESPONSE_LANGUAGE=de for a German-speaking audience; defaults to "en".
# This is independent of the transcription source and the translation target
# (translation output still follows the chosen target language); unsupported
# values fall back to English.
# NEXTEXT_RESPONSE_LANGUAGE=en
#
# Summarization context budget — max transcript tokens sent to TEXT_MODEL in a
# single request. Longer transcripts are summarized map-reduce (chunk, summarize
# each, then summarize the combined summaries) so they never overflow the
# model's context window. Lower it for small max_model_len backends or
# token-dense scripts (e.g. CJK); raise it to reduce chunking. Defaults to 6000.
# SUMMARY_MAX_INPUT_TOKENS=6000
# =============================================================================

# --- Option 1: Ollama --------------------------------------------------------
# Ollama covers the text tasks only; transcription additionally needs the
# dedicated WHISPER_API_BASE + WHISPER_MODEL pair (see above).
# INFERENCE_PROVIDER=ollama
# OPENAI_API_BASE=http://ollama:11434/v1
# OPENAI_API_KEY=ollama
# TEXT_MODEL=gpt-oss:20b
# OLLAMA_THINK=0  # disable chain-of-thought on Qwen3 etc. (no-op for vLLM/openai)

# --- Option 2: vLLM via LiteLLM (nos-tromo/vllm-service) ---------------------
# One endpoint serves chat and Whisper (/v1/audio/transcriptions); NER,
# diarization, and VAD default to it too (root path, /v1 stripped), so no
# dedicated *_API_BASE overrides are needed.
# INFERENCE_PROVIDER=vllm
# OPENAI_API_BASE=http://vllm-router:4000/v1
# OPENAI_API_KEY=<litellm master key>
# TEXT_MODEL=Qwen/Qwen3.5-35B-A3B-GPTQ-Int4

# --- Option 3: OpenAI (hosted) -----------------------------------------------
# Chat + Whisper served by OpenAI; NER/diarization still need dedicated
# endpoints (api.openai.com has no /gliner or /diarize).
# INFERENCE_PROVIDER=openai
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# TEXT_MODEL=gpt-4o

# Proxy bypass: NO_PROXY/no_proxy are set in docker-compose.yml with sensible
# defaults (service aliases + private CIDR ranges). To append extra hostnames,
# set EXTRA_NO_PROXY below (must start with a leading comma):
# EXTRA_NO_PROXY=,ollama,vllm-router,docint-backend
